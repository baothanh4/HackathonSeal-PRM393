# ================================================
# HackathonSeal - Environment Variables Template
# ================================================
# Sao chép file này thành .env và điền giá trị thật
# KHÔNG commit file .env lên Git!
# ================================================

# === Database ===
DB_URL=jdbc:postgresql://localhost:5432/hackathonseal
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# === JWT ===
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# === Gmail SMTP ===
# Tạo App Password tại: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx

# === App Config ===
APP_BASE_URL=http://localhost:8081
APP_EMAIL_VERIFICATION_EXPIRY_MINUTES=1440
APP_PASSWORD_RESET_EXPIRY_MINUTES=15
